model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")

  userSkills         UserSkills[]
  userGoal           UserGoal?
  roadmaps           Roadmap[]
  userSavedRoadmaps  UserSavedRoadmap[]
  userNodeProgresses UserNodeProgress[]
  refreshTokens      RefreshToken[]

  @@index([createdAt])
  @@map("users")
}

model UserSkills {
  proficiency SkillProficiency @default(NONE)
  updatedAt   DateTime         @default(now()) @map("updated_at")

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String @map("skill_id")
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([userId])
  @@map("user_skills")
}

model UserGoal {
  currentLevel   SkillLevel? @map("current_level")
  hoursPerDay    Int         @map("hours_per_day")
  deadlineMonths Int         @map("deadline_months")
  updatedAt      DateTime    @default(now()) @map("updated_at")

  userId       String @id @map("user_id")
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetRoleId String @map("target_role_id")
  targetRole   Role   @relation(fields: [targetRoleId], references: [id], onDelete: Restrict)

  @@map("user_goals")
}

model UserSavedRoadmap {
  savedAt DateTime @default(now()) @map("saved_at")

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapId String  @map("roadmap_id")
  roadmap   Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@id([userId, roadmapId])
  @@map("user_saved_roadmaps")
}

model UserNodeProgress {
  status      NodeStatus @default(LOCKED)
  startedAt   DateTime?  @map("started_at")
  completedAt DateTime?  @map("completed_at")

  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmapNodeId String      @map("roadmap_node_id")
  roadmapNode   RoadmapNode @relation(fields: [roadmapNodeId], references: [id], onDelete: Cascade)

  @@id([userId, roadmapNodeId])
  @@index([userId])
  @@map("user_node_progress")
}
